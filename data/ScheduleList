<!DOCTYPE html>
<meta charset="UTF-8">
<html>

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Irrigation Schedule List</title>
    <link rel="stylesheet" href="site.css">
</head>

<body>
    <div class="container">
        <div class="header">
            <span>Irrigation Schedule List</span>
        </div>
        <div class="content">
            <div class="scheduleList">
                <div class="listItem">
                    Time
                </div>
                <div class="listItem">
                    Weight
                </div>
                <div class="listItem">

                </div>
                %SCHEDULES%
            </div>
        </div>
        <div class="buttonLine">
            <button type="button" onclick="window.location.href='/DownloadSchedules';">Download</button>
            <form id="uploadForm" style="display:inline;" enctype="multipart/form-data" method="post" action="/UploadSchedules">
                <input type="file" name="schedules" id="scheduleFile" accept=".json" style="display:none;" onchange="document.getElementById('uploadForm').submit();">
                <button type="button" onclick="document.getElementById('scheduleFile').click();">Upload</button>
            </form>
            <button type="button" onclick="window.location.href='/';">Cancel</button>
            <button type="submit" onclick="window.location.href='/Schedule';">Add</button>
        </div>
        <div class="footer">
            Irrigation system 2022
        </div>
    </div>
    <script src="script.js"></script>
</body>

</html>